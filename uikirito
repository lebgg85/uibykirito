-- VanityUI Library - Version Finale (Mobile Friendly + Dropdown Beau + Animations Fluides + Hotkey + Position Droite)
local Vanity = {}

function Vanity:MakeWindow(options)
	local self = { Tabs = {}, CurrentTab = nil, Visible = true }

	local TweenService = game:GetService("TweenService")
	local UserInputService = game:GetService("UserInputService")

	-- Détection mobile pour adapter la taille (plus petit sur téléphone)
	local isMobile = UserInputService.TouchEnabled
	local baseWidth = isMobile and 310 or 420
	local baseHeight = isMobile and 410 or 530

	local ScreenGui = Instance.new("ScreenGui")
	ScreenGui.Name = "VanityUI"
	ScreenGui.ResetOnSpawn = false
	ScreenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")

	-- Main Frame (positionnée à DROITE de l'écran dès le lancement)
	local Main = Instance.new("Frame")
	Main.Size = UDim2.new(0, baseWidth, 0, baseHeight)
	Main.Position = UDim2.new(1, -baseWidth - 20, 0.5, -baseHeight/2) -- droite avec petit padding
	Main.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
	Main.BorderSizePixel = 0
	Main.Visible = true
	Main.Parent = ScreenGui

	local MainCorner = Instance.new("UICorner")
	MainCorner.CornerRadius = UDim.new(0, 16)
	MainCorner.Parent = Main

	local Stroke = Instance.new("UIStroke")
	Stroke.Color = Color3.fromRGB(0, 162, 255)
	Stroke.Thickness = 3
	Stroke.Parent = Main

	-- Header bleu VANITY
	local Header = Instance.new("Frame")
	Header.Size = UDim2.new(1, 0, 0, 85)
	Header.BackgroundColor3 = Color3.fromRGB(0, 110, 255)
	Header.Parent = Main

	local HeaderGradient = Instance.new("UIGradient")
	HeaderGradient.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, Color3.fromRGB(40, 180, 255)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 70, 220))
	}
	HeaderGradient.Parent = Header

	local HCorner = Instance.new("UICorner")
	HCorner.CornerRadius = UDim.new(0, 16)
	HCorner.Parent = Header

	-- Logo V + VANITY
	local V = Instance.new("TextLabel")
	V.Size = UDim2.new(0, 58, 0, 58)
	V.Position = UDim2.new(0, 20, 0.5, -29)
	V.BackgroundTransparency = 1
	V.Text = "V"
	V.TextColor3 = Color3.fromRGB(0, 230, 255)
	V.TextScaled = true
	V.Font = Enum.Font.GothamBlack
	V.Parent = Header

	local VanityText = Instance.new("TextLabel")
	VanityText.Size = UDim2.new(0.6, 0, 0, 55)
	VanityText.Position = UDim2.new(0.22, 0, 0.5, -27)
	VanityText.BackgroundTransparency = 1
	VanityText.Text = "VANITY"
	VanityText.TextColor3 = Color3.new(1,1,1)
	VanityText.TextScaled = true
	VanityText.Font = Enum.Font.GothamBlack
	VanityText.Parent = Header

	-- Bouton fermer (X) - visible sur mobile et PC
	local CloseBtn = Instance.new("TextButton")
	CloseBtn.Size = UDim2.new(0, 34, 0, 34)
	CloseBtn.Position = UDim2.new(1, -42, 0, 8)
	CloseBtn.BackgroundTransparency = 1
	CloseBtn.Text = "✕"
	CloseBtn.TextColor3 = Color3.new(1,1,1)
	CloseBtn.TextScaled = true
	CloseBtn.Font = Enum.Font.GothamBold
	CloseBtn.Parent = Header

	CloseBtn.MouseButton1Click:Connect(function()
		self:Toggle()
	end)

	-- Title Bar
	local TitleBar = Instance.new("Frame")
	TitleBar.Size = UDim2.new(1, 0, 0, 40)
	TitleBar.Position = UDim2.new(0, 0, 0, 85)
	TitleBar.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
	TitleBar.Parent = Main

	self.TitleLabel = Instance.new("TextLabel")
	self.TitleLabel.Size = UDim2.new(1, 0, 1, 0)
	self.TitleLabel.BackgroundTransparency = 1
	self.TitleLabel.Text = "Misc"
	self.TitleLabel.TextColor3 = Color3.new(1,1,1)
	self.TitleLabel.Font = Enum.Font.GothamBold
	self.TitleLabel.TextScaled = true
	self.TitleLabel.Parent = TitleBar

	-- Tab Bar (exactement comme la photo : Misc en bleu quand sélectionné)
	local TabBar = Instance.new("Frame")
	TabBar.Size = UDim2.new(1, 0, 0, 45)
	TabBar.Position = UDim2.new(0, 0, 0, 125)
	TabBar.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
	TabBar.Parent = Main

	local TabList = Instance.new("UIListLayout")
	TabList.FillDirection = Enum.FillDirection.Horizontal
	TabList.SortOrder = Enum.SortOrder.LayoutOrder
	TabList.Padding = UDim.new(0, 4)
	TabList.Parent = TabBar

	-- Content
	local Content = Instance.new("Frame")
	Content.Size = UDim2.new(1, 0, 1, -200)
	Content.Position = UDim2.new(0, 0, 0, 170)
	Content.BackgroundTransparency = 1
	Content.Parent = Main

	-- Footer
	local Footer = Instance.new("Frame")
	Footer.Size = UDim2.new(1, 0, 0, 30)
	Footer.Position = UDim2.new(0, 0, 1, -30)
	Footer.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
	Footer.Parent = Main

	local FooterText = Instance.new("TextLabel")
	FooterText.Size = UDim2.new(1,0,1,0)
	FooterText.BackgroundTransparency = 1
	FooterText.Text = "Build 51538 | discord.gg/vanitymenu   2 / 8"
	FooterText.TextColor3 = Color3.fromRGB(140, 140, 140)
	FooterText.Font = Enum.Font.Gotham
	FooterText.TextScaled = true
	FooterText.Parent = Footer

	-- Draggable (fonctionne aussi sur mobile avec toucher)
	local dragging = false
	Header.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			local startPos = Main.Position
			local startInput = input.Position
			local conn
			conn = game:GetService("RunService").RenderStepped:Connect(function()
				if dragging then
					local delta = UserInputService:GetMouseLocation() - startInput
					Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
				end
			end)
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
					if conn then conn:Disconnect() end
				end
			end)
		end
	end)

	-- Fonction Toggle (ouvrir/fermer le menu)
	function self:Toggle()
		self.Visible = not self.Visible
		local goal = {Size = UDim2.new(0, baseWidth, 0, self.Visible and baseHeight or 0)}
		TweenService:Create(Main, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), goal):Play()
		Main.Visible = true -- on garde visible mais on réduit la hauteur pour une belle animation
	end

	-- Hotkey RightShift (ou F4 si tu veux changer)
	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then return end
		if input.KeyCode == Enum.KeyCode.RightShift or input.KeyCode == Enum.KeyCode.F4 then
			self:Toggle()
		end
	end)

	-- Create Tab
	function self:CreateTab(name)
		local TabButton = Instance.new("TextButton")
		TabButton.Size = UDim2.new(0.333, 0, 1, 0)
		TabButton.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
		TabButton.Text = name
		TabButton.TextColor3 = Color3.new(1,1,1)
		TabButton.Font = Enum.Font.GothamBold
		TabButton.TextScaled = true
		TabButton.BorderSizePixel = 0
		TabButton.Parent = TabBar

		local TabCorner = Instance.new("UICorner")
		TabCorner.CornerRadius = UDim.new(0, 8)
		TabCorner.Parent = TabButton

		local Page = Instance.new("ScrollingFrame")
		Page.Size = UDim2.new(1, 0, 1, 0)
		Page.BackgroundTransparency = 1
		Page.ScrollBarThickness = 5
		Page.Visible = false
		Page.Parent = Content

		local ListLayout = Instance.new("UIListLayout")
		ListLayout.Padding = UDim.new(0, 8)
		ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
		ListLayout.Parent = Page

		-- Animation fluide quand on change de tab
		TabButton.MouseButton1Click:Connect(function()
			if self.CurrentTab then
				self.CurrentTab.Button.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
				local fadeOut = TweenService:Create(self.CurrentTab.Page, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundTransparency = 1})
				fadeOut:Play()
				self.CurrentTab.Page.Visible = false
			end

			Page.Visible = true
			TabButton.BackgroundColor3 = Color3.fromRGB(0, 162, 255)
			self.TitleLabel.Text = name
			self.CurrentTab = {Page = Page, Button = TabButton}
		end)

		local Tab = {}

		-- Toggle (animation fluide déjà présente)
		function Tab:AddToggle(name, default, callback)
			-- (code identique à la version précédente mais avec tween plus fluide)
			local Frame = Instance.new("Frame")
			Frame.Size = UDim2.new(1, -20, 0, 50)
			Frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
			Frame.Parent = Page

			local Corner = Instance.new("UICorner")
			Corner.CornerRadius = UDim.new(0, 10)
			Corner.Parent = Frame

			local Label = Instance.new("TextLabel")
			Label.Size = UDim2.new(0.7, 0, 1, 0)
			Label.BackgroundTransparency = 1
			Label.Text = name
			Label.TextXAlignment = Enum.TextXAlignment.Left
			Label.TextColor3 = Color3.new(1,1,1)
			Label.Font = Enum.Font.Gotham
			Label.TextScaled = true
			Label.Parent = Frame

			local Switch = Instance.new("Frame")
			Switch.Size = UDim2.new(0, 62, 0, 32)
			Switch.Position = UDim2.new(0.82, 0, 0.5, -16)
			Switch.BackgroundColor3 = default and Color3.fromRGB(0, 162, 255) or Color3.fromRGB(60, 60, 60)
			Switch.Parent = Frame

			local SC = Instance.new("UICorner")
			SC.CornerRadius = UDim.new(1, 0)
			SC.Parent = Switch

			local Knob = Instance.new("Frame")
			Knob.Size = UDim2.new(0, 28, 0, 28)
			Knob.Position = UDim2.new(default and 1 or 0, default and -28 or 0, 0.5, -14)
			Knob.BackgroundColor3 = Color3.new(1,1,1)
			Knob.Parent = Switch

			local KC = Instance.new("UICorner")
			KC.CornerRadius = UDim.new(1, 0)
			KC.Parent = Knob

			local state = default
			local function Update()
				local colorGoal = {BackgroundColor3 = state and Color3.fromRGB(0, 162, 255) or Color3.fromRGB(60, 60, 60)}
				TweenService:Create(Switch, TweenInfo.new(0.25, Enum.EasingStyle.Quint), colorGoal):Play()
				Knob:TweenPosition(UDim2.new(state and 1 or 0, state and -28 or 0, 0.5, -14), "Out", "Quint", 0.25, true)
			end

			Switch.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
					state = not state
					Update()
					if callback then callback(state) end
				end
			end)
			Update()
		end

		-- Slider (animation fluide)
		function Tab:AddSlider(name, min, max, default, callback)
			-- (code identique à la version précédente avec tween sur le fill)
			local Frame = Instance.new("Frame")
			Frame.Size = UDim2.new(1, -20, 0, 65)
			Frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
			Frame.Parent = Page

			local Corner = Instance.new("UICorner")
			Corner.CornerRadius = UDim.new(0, 10)
			Corner.Parent = Frame

			local Label = Instance.new("TextLabel")
			Label.Size = UDim2.new(1, 0, 0, 25)
			Label.BackgroundTransparency = 1
			Label.Text = name
			Label.TextXAlignment = Enum.TextXAlignment.Left
			Label.TextColor3 = Color3.new(1,1,1)
			Label.Font = Enum.Font.Gotham
			Label.TextScaled = true
			Label.Parent = Frame

			local SliderBar = Instance.new("Frame")
			SliderBar.Size = UDim2.new(0.9, 0, 0, 8)
			SliderBar.Position = UDim2.new(0.05, 0, 0.65, 0)
			SliderBar.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
			SliderBar.Parent = Frame

			local SCorner = Instance.new("UICorner")
			SCorner.CornerRadius = UDim.new(1, 0)
			SCorner.Parent = SliderBar

			local Fill = Instance.new("Frame")
			Fill.Size = UDim2.new(0, 0, 1, 0)
			Fill.BackgroundColor3 = Color3.fromRGB(0, 162, 255)
			Fill.Parent = SliderBar

			local FCorner = Instance.new("UICorner")
			FCorner.CornerRadius = UDim.new(1, 0)
			FCorner.Parent = Fill

			local ValueLabel = Instance.new("TextLabel")
			ValueLabel.Size = UDim2.new(0.1, 0, 0, 20)
			ValueLabel.Position = UDim2.new(0.9, 0, 0.5, -10)
			ValueLabel.BackgroundTransparency = 1
			ValueLabel.Text = tostring(default)
			ValueLabel.TextColor3 = Color3.new(1,1,1)
			ValueLabel.Font = Enum.Font.Gotham
			ValueLabel.TextScaled = true
			ValueLabel.Parent = Frame

			local value = default
			local dragging = false

			local function UpdateSlider()
				local percent = (value - min) / (max - min)
				TweenService:Create(Fill, TweenInfo.new(0.15, Enum.EasingStyle.Quint), {Size = UDim2.new(percent, 0, 1, 0)}):Play()
				ValueLabel.Text = tostring(math.floor(value))
				if callback then callback(value) end
			end

			SliderBar.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
					dragging = true
				end
			end)

			UserInputService.InputEnded:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
					dragging = false
				end
			end)

			game:GetService("RunService").RenderStepped:Connect(function()
				if dragging then
					local mouseX = UserInputService:GetMouseLocation().X
					local barPos = SliderBar.AbsolutePosition.X
					local barSize = SliderBar.AbsoluteSize.X
					local percent = math.clamp((mouseX - barPos) / barSize, 0, 1)
					value = min + (max - min) * percent
					UpdateSlider()
				end
			end)

			UpdateSlider()
		end

		-- DROPDOWN BEAU avec liste qui descend (animation fluide)
		function Tab:AddDropdown(name, options, default, callback)
			local Frame = Instance.new("Frame")
			Frame.Size = UDim2.new(1, -20, 0, 50)
			Frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
			Frame.Parent = Page

			local Corner = Instance.new("UICorner")
			Corner.CornerRadius = UDim.new(0, 10)
			Corner.Parent = Frame

			local Label = Instance.new("TextLabel")
			Label.Size = UDim2.new(0.65, 0, 1, 0)
			Label.BackgroundTransparency = 1
			Label.Text = name
			Label.TextXAlignment = Enum.TextXAlignment.Left
			Label.TextColor3 = Color3.new(1,1,1)
			Label.Font = Enum.Font.Gotham
			Label.TextScaled = true
			Label.Parent = Frame

			local DropdownBtn = Instance.new("TextButton")
			DropdownBtn.Size = UDim2.new(0.32, 0, 0.8, 0)
			DropdownBtn.Position = UDim2.new(0.66, 0, 0.1, 0)
			DropdownBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
			DropdownBtn.Text = default or options[1]
			DropdownBtn.TextColor3 = Color3.new(1,1,1)
			DropdownBtn.Font = Enum.Font.Gotham
			DropdownBtn.TextScaled = true
			DropdownBtn.Parent = Frame

			local DCorner = Instance.new("UICorner")
			DCorner.CornerRadius = UDim.new(0, 8)
			DCorner.Parent = DropdownBtn

			-- Liste qui descend
			local ListFrame = Instance.new("Frame")
			ListFrame.Size = UDim2.new(0.32, 0, 0, 0)
			ListFrame.Position = UDim2.new(0.66, 0, 1, 8)
			ListFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
			ListFrame.BorderSizePixel = 0
			ListFrame.Visible = false
			ListFrame.Parent = Frame  -- attaché au dropdown

			local LCorner = Instance.new("UICorner")
			LCorner.CornerRadius = UDim.new(0, 10)
			LCorner.Parent = ListFrame

			local ListScrolling = Instance.new("ScrollingFrame")
			ListScrolling.Size = UDim2.new(1, 0, 1, 0)
			ListScrolling.BackgroundTransparency = 1
			ListScrolling.ScrollBarThickness = 4
			ListScrolling.Parent = ListFrame

			local ListLayout2 = Instance.new("UIListLayout")
			ListLayout2.Padding = UDim.new(0, 2)
			ListLayout2.SortOrder = Enum.SortOrder.LayoutOrder
			ListLayout2.Parent = ListScrolling

			local open = false
			local currentHeight = 0

			DropdownBtn.MouseButton1Click:Connect(function()
				open = not open
				if open then
					-- Calcul de la hauteur max (max 5 options visibles)
					currentHeight = math.min(#options * 38, 190)
					ListFrame.Visible = true
					TweenService:Create(ListFrame, TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
						Size = UDim2.new(0.32, 0, 0, currentHeight)
					}):Play()
				else
					TweenService:Create(ListFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {
						Size = UDim2.new(0.32, 0, 0, 0)
					}):Play()
					task.wait(0.3)
					ListFrame.Visible = false
				end
			end)

			-- Ajout des options dans la liste
			for _, opt in ipairs(options) do
				local OptionBtn = Instance.new("TextButton")
				OptionBtn.Size = UDim2.new(1, 0, 0, 36)
				OptionBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
				OptionBtn.Text = opt
				OptionBtn.TextColor3 = Color3.new(1,1,1)
				OptionBtn.Font = Enum.Font.Gotham
				OptionBtn.TextScaled = true
				OptionBtn.Parent = ListScrolling

				local OCorner = Instance.new("UICorner")
				OCorner.CornerRadius = UDim.new(0, 6)
				OCorner.Parent = OptionBtn

				OptionBtn.MouseButton1Click:Connect(function()
					DropdownBtn.Text = opt
					open = false
					TweenService:Create(ListFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quint), {Size = UDim2.new(0.32, 0, 0, 0)}):Play()
					task.wait(0.25)
					ListFrame.Visible = false
					if callback then callback(opt) end
				end)
			end

			ListScrolling.CanvasSize = UDim2.new(0, 0, 0, #options * 38)
		end

		-- Button avec " > " comme sur ta photo
		function Tab:AddButton(name, callback)
			local Frame = Instance.new("Frame")
			Frame.Size = UDim2.new(1, -20, 0, 45)
			Frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
			Frame.Parent = Page

			local Corner = Instance.new("UICorner")
			Corner.CornerRadius = UDim.new(0, 10)
			Corner.Parent = Frame

			local Btn = Instance.new("TextButton")
			Btn.Size = UDim2.new(1, 0, 1, 0)
			Btn.BackgroundTransparency = 1
			Btn.Text = name .. "   >"
			Btn.TextXAlignment = Enum.TextXAlignment.Left
			Btn.TextColor3 = Color3.new(1,1,1)
			Btn.Font = Enum.Font.Gotham
			Btn.TextScaled = true
			Btn.Parent = Frame

			Btn.MouseButton1Click:Connect(function()
				if callback then callback() end
			end)
		end

		-- Section Advanced
		function Tab:AddSection(text)
			local Sep = Instance.new("Frame")
			Sep.Size = UDim2.new(1, -20, 0, 35)
			Sep.BackgroundTransparency = 1
			Sep.Parent = Page

			local Line = Instance.new("Frame")
			Line.Size = UDim2.new(1, 0, 0, 2)
			Line.Position = UDim2.new(0, 0, 0.5, 0)
			Line.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
			Line.Parent = Sep

			local TextLabel = Instance.new("TextLabel")
			TextLabel.Size = UDim2.new(0, 140, 1, 0)
			TextLabel.Position = UDim2.new(0.5, -70, 0, 0)
			TextLabel.BackgroundTransparency = 1
			TextLabel.Text = text
			TextLabel.TextColor3 = Color3.fromRGB(160, 160, 160)
			TextLabel.Font = Enum.Font.GothamBold
			TextLabel.TextScaled = true
			TextLabel.Parent = Sep
		end

		-- Premier tab sélectionné
		if not self.CurrentTab then
			TabButton.BackgroundColor3 = Color3.fromRGB(0, 162, 255)
			Page.Visible = true
			self.TitleLabel.Text = name
			self.CurrentTab = {Page = Page, Button = TabButton}
		end

		return Tab
	end

	-- Retourne l'objet pour l'utiliser
	return self
end

return Vanity
