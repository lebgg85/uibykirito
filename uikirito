-- AquaPulse UI - Menu à gauche + Draggable
local AquaPulse = {}

function AquaPulse:MakeWindow()
	local self = { Visible = true, CurrentTab = nil }

	local TweenService = game:GetService("TweenService")
	local UserInputService = game:GetService("UserInputService")

	local isMobile = UserInputService.TouchEnabled
	local width = isMobile and 310 or 400
	local height = isMobile and 460 or 530

	local ScreenGui = Instance.new("ScreenGui")
	ScreenGui.Name = "AquaPulseUI"
	ScreenGui.ResetOnSpawn = false
	ScreenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")

	-- Main Frame - OUVERT À GAUCHE
	local Main = Instance.new("Frame")
	Main.Size = UDim2.new(0, width, 0, height)
	Main.Position = UDim2.new(0, 20, 0.5, -height/2)   -- Bien à gauche avec petit padding
	Main.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
	Main.BorderSizePixel = 0
	Main.Parent = ScreenGui

	local MainCorner = Instance.new("UICorner")
	MainCorner.CornerRadius = UDim.new(0, 16)
	MainCorner.Parent = Main

	local Stroke = Instance.new("UIStroke")
	Stroke.Color = Color3.fromRGB(0, 170, 255)
	Stroke.Thickness = 3
	Stroke.Parent = Main

	-- Header bleu AQUAPULSE
	local Header = Instance.new("Frame")
	Header.Size = UDim2.new(1, 0, 0, 90)
	Header.BackgroundColor3 = Color3.fromRGB(0, 110, 255)
	Header.Parent = Main

	local HeaderGradient = Instance.new("UIGradient")
	HeaderGradient.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, Color3.fromRGB(40, 200, 255)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 80, 220))
	}
	HeaderGradient.Parent = Header

	local HCorner = Instance.new("UICorner")
	HCorner.CornerRadius = UDim.new(0, 16)
	HCorner.Parent = Header

	-- Logo A + AQUAPULSE
	local ALogo = Instance.new("TextLabel")
	ALogo.Size = UDim2.new(0, 68, 0, 68)
	ALogo.Position = UDim2.new(0, 25, 0.5, -34)
	ALogo.BackgroundTransparency = 1
	ALogo.Text = "A"
	ALogo.TextColor3 = Color3.fromRGB(0, 240, 255)
	ALogo.TextScaled = true
	ALogo.Font = Enum.Font.GothamBlack
	ALogo.Parent = Header

	local TitleText = Instance.new("TextLabel")
	TitleText.Size = UDim2.new(0.65, 0, 0, 60)
	TitleText.Position = UDim2.new(0.24, 0, 0.5, -30)
	TitleText.BackgroundTransparency = 1
	TitleText.Text = "AQUAPULSE"
	TitleText.TextColor3 = Color3.new(1,1,1)
	TitleText.TextScaled = true
	TitleText.Font = Enum.Font.GothamBlack
	TitleText.Parent = Header

	-- Boutons − et ✕
	local ButtonFrame = Instance.new("Frame")
	ButtonFrame.Size = UDim2.new(0, 90, 0, 40)
	ButtonFrame.Position = UDim2.new(1, -100, 0, 8)
	ButtonFrame.BackgroundTransparency = 1
	ButtonFrame.Parent = Header

	local MinimizeBtn = Instance.new("TextButton")
	MinimizeBtn.Size = UDim2.new(0, 38, 0, 38)
	MinimizeBtn.Position = UDim2.new(0, 0, 0.5, -19)
	MinimizeBtn.BackgroundTransparency = 1
	MinimizeBtn.Text = "−"
	MinimizeBtn.TextColor3 = Color3.new(1,1,1)
	MinimizeBtn.TextScaled = true
	MinimizeBtn.Font = Enum.Font.GothamBold
	MinimizeBtn.Parent = ButtonFrame

	local CloseBtn = Instance.new("TextButton")
	CloseBtn.Size = UDim2.new(0, 38, 0, 38)
	CloseBtn.Position = UDim2.new(1, -38, 0.5, -19)
	CloseBtn.BackgroundTransparency = 1
	CloseBtn.Text = "✕"
	CloseBtn.TextColor3 = Color3.new(1,1,1)
	CloseBtn.TextScaled = true
	CloseBtn.Font = Enum.Font.GothamBold
	CloseBtn.Parent = ButtonFrame

	-- Title Bar
	local TitleBar = Instance.new("Frame")
	TitleBar.Size = UDim2.new(1, 0, 0, 40)
	TitleBar.Position = UDim2.new(0, 0, 0, 90)
	TitleBar.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
	TitleBar.Parent = Main

	self.TitleLabel = Instance.new("TextLabel")
	self.TitleLabel.Size = UDim2.new(1, 0, 1, 0)
	self.TitleLabel.BackgroundTransparency = 1
	self.TitleLabel.Text = "Misc"
	self.TitleLabel.TextColor3 = Color3.new(1,1,1)
	self.TitleLabel.Font = Enum.Font.GothamBold
	self.TitleLabel.TextScaled = true
	self.TitleLabel.Parent = TitleBar

	-- Tab Bar (avec scroll si trop de tabs)
	local TabBarFrame = Instance.new("Frame")
	TabBarFrame.Size = UDim2.new(1, 0, 0, 45)
	TabBarFrame.Position = UDim2.new(0, 0, 0, 130)
	TabBarFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
	TabBarFrame.Parent = Main

	local TabScroll = Instance.new("ScrollingFrame")
	TabScroll.Size = UDim2.new(1, 0, 1, 0)
	TabScroll.BackgroundTransparency = 1
	TabScroll.ScrollBarThickness = 4
	TabScroll.Parent = TabBarFrame

	local TabLayout = Instance.new("UIListLayout")
	TabLayout.FillDirection = Enum.FillDirection.Horizontal
	TabLayout.SortOrder = Enum.SortOrder.LayoutOrder
	TabLayout.Padding = UDim.new(0, 6)
	TabLayout.Parent = TabScroll

	-- Content Scrolling
	local Content = Instance.new("ScrollingFrame")
	Content.Size = UDim2.new(1, 0, 1, -205)
	Content.Position = UDim2.new(0, 0, 0, 175)
	Content.BackgroundTransparency = 1
	Content.ScrollBarThickness = 5
	Content.Parent = Main

	local ListLayout = Instance.new("UIListLayout")
	ListLayout.Padding = UDim.new(0, 8)
	ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
	ListLayout.Parent = Content

	-- Footer
	local Footer = Instance.new("Frame")
	Footer.Size = UDim2.new(1, 0, 0, 30)
	Footer.Position = UDim2.new(0, 0, 1, -30)
	Footer.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
	Footer.Parent = Main

	local FooterText = Instance.new("TextLabel")
	FooterText.Size = UDim2.new(1,0,1,0)
	FooterText.BackgroundTransparency = 1
	FooterText.Text = "Build 51538 | discord.gg/ZCU9uMUcz6"
	FooterText.TextColor3 = Color3.fromRGB(140, 140, 140)
	FooterText.Font = Enum.Font.Gotham
	FooterText.TextScaled = true
	FooterText.Parent = Footer

	-- === DRAGGABLE (très fluide) ===
	local dragging = false
	local dragStart, startPos

	Header.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = Main.Position

			local conn
			conn = game:GetService("RunService").RenderStepped:Connect(function()
				if dragging then
					local delta = UserInputService:GetMouseLocation() - dragStart
					Main.Position = UDim2.new(
						startPos.X.Scale,
						startPos.X.Offset + delta.X,
						startPos.Y.Scale,
						startPos.Y.Offset + delta.Y
					)
				end
			end)

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
					if conn then conn:Disconnect() end
				end
			end)
		end
	end)

	-- Boutons
	MinimizeBtn.MouseButton1Click:Connect(function()
		self:Toggle()
	end)

	CloseBtn.MouseButton1Click:Connect(function()
		Main:Destroy()
	end)

	function self:Toggle()
		self.Visible = not self.Visible
		local targetHeight = self.Visible and height or 90
		TweenService:Create(Main, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {Size = UDim2.new(0, width, 0, targetHeight)}):Play()
	end

	-- Create Tab
	function self:CreateTab(name)
		local TabButton = Instance.new("TextButton")
		TabButton.Size = UDim2.new(0, 110, 1, 0)
		TabButton.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
		TabButton.Text = name
		TabButton.TextColor3 = Color3.new(1,1,1)
		TabButton.Font = Enum.Font.GothamBold
		TabButton.TextScaled = true
		TabButton.Parent = TabScroll

		local TabCorner = Instance.new("UICorner")
		TabCorner.CornerRadius = UDim.new(0, 8)
		TabCorner.Parent = TabButton

		local Page = Instance.new("ScrollingFrame")
		Page.Size = UDim2.new(1, 0, 1, 0)
		Page.BackgroundTransparency = 1
		Page.ScrollBarThickness = 5
		Page.Visible = false
		Page.Parent = Content

		local PageList = Instance.new("UIListLayout")
		PageList.Padding = UDim.new(0, 8)
		PageList.SortOrder = Enum.SortOrder.LayoutOrder
		PageList.Parent = Page

		TabButton.MouseButton1Click:Connect(function()
			if self.CurrentTab then
				self.CurrentTab.Button.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
				self.CurrentTab.Page.Visible = false
			end
			Page.Visible = true
			TabButton.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
			self.TitleLabel.Text = name
			self.CurrentTab = {Page = Page, Button = TabButton}
		end)

		-- Auto-scroll du TabBar si beaucoup de tabs
		TabScroll.CanvasSize = UDim2.new(0, TabLayout.AbsoluteContentSize.X + 20, 0, 0)

		local Tab = {}

		function Tab:AddToggle(name, default, callback)
			local Frame = Instance.new("Frame")
			Frame.Size = UDim2.new(1, -20, 0, 50)
			Frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
			Frame.Parent = Page

			local Corner = Instance.new("UICorner")
			Corner.CornerRadius = UDim.new(0, 10)
			Corner.Parent = Frame

			local Label = Instance.new("TextLabel")
			Label.Size = UDim2.new(0.7, 0, 1, 0)
			Label.BackgroundTransparency = 1
			Label.Text = name
			Label.TextXAlignment = Enum.TextXAlignment.Left
			Label.TextColor3 = Color3.new(1,1,1)
			Label.Font = Enum.Font.Gotham
			Label.TextScaled = true
			Label.Parent = Frame

			local Switch = Instance.new("Frame")
			Switch.Size = UDim2.new(0, 62, 0, 32)
			Switch.Position = UDim2.new(0.82, 0, 0.5, -16)
			Switch.BackgroundColor3 = default and Color3.fromRGB(0, 170, 255) or Color3.fromRGB(60, 60, 60)
			Switch.Parent = Frame

			local SC = Instance.new("UICorner")
			SC.CornerRadius = UDim.new(1, 0)
			SC.Parent = Switch

			local Knob = Instance.new("Frame")
			Knob.Size = UDim2.new(0, 28, 0, 28)
			Knob.Position = UDim2.new(default and 1 or 0, default and -28 or 0, 0.5, -14)
			Knob.BackgroundColor3 = Color3.new(1,1,1)
			Knob.Parent = Switch

			local KC = Instance.new("UICorner")
			KC.CornerRadius = UDim.new(1, 0)
			KC.Parent = Knob

			local state = default
			local function Update()
				TweenService:Create(Switch, TweenInfo.new(0.25, Enum.EasingStyle.Quint), {
					BackgroundColor3 = state and Color3.fromRGB(0, 170, 255) or Color3.fromRGB(60, 60, 60)
				}):Play()
				Knob:TweenPosition(UDim2.new(state and 1 or 0, state and -28 or 0, 0.5, -14), "Out", "Quint", 0.25, true)
			end

			Switch.InputBegan:Connect(function(i)
				if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
					state = not state
					Update()
					if callback then callback(state) end
				end
			end)
			Update()
		end

		function Tab:AddButton(name, callback)
			local Frame = Instance.new("Frame")
			Frame.Size = UDim2.new(1, -20, 0, 45)
			Frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
			Frame.Parent = Page

			local Corner = Instance.new("UICorner")
			Corner.CornerRadius = UDim.new(0, 10)
			Corner.Parent = Frame

			local Btn = Instance.new("TextButton")
			Btn.Size = UDim2.new(1,0,1,0)
			Btn.BackgroundTransparency = 1
			Btn.Text = name .. "   >"
			Btn.TextXAlignment = Enum.TextXAlignment.Left
			Btn.TextColor3 = Color3.new(1,1,1)
			Btn.Font = Enum.Font.Gotham
			Btn.TextScaled = true
			Btn.Parent = Frame

			Btn.MouseButton1Click:Connect(callback or function() end)
		end

		function Tab:AddSection(text)
			local Sep = Instance.new("Frame")
			Sep.Size = UDim2.new(1, -20, 0, 35)
			Sep.BackgroundTransparency = 1
			Sep.Parent = Page

			local Line = Instance.new("Frame")
			Line.Size = UDim2.new(1, 0, 0, 2)
			Line.Position = UDim2.new(0, 0, 0.5, 0)
			Line.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
			Line.Parent = Sep

			local Txt = Instance.new("TextLabel")
			Txt.Size = UDim2.new(0, 140, 1, 0)
			Txt.Position = UDim2.new(0.5, -70, 0, 0)
			Txt.BackgroundTransparency = 1
			Txt.Text = text
			Txt.TextColor3 = Color3.fromRGB(160, 160, 160)
			Txt.Font = Enum.Font.GothamBold
			Txt.TextScaled = true
			Txt.Parent = Sep
		end

		function Tab:AddDropdown(name, options, default, callback)
			local Frame = Instance.new("Frame")
			Frame.Size = UDim2.new(1, -20, 0, 50)
			Frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
			Frame.Parent = Page

			local Corner = Instance.new("UICorner")
			Corner.CornerRadius = UDim.new(0, 10)
			Corner.Parent = Frame

			local Label = Instance.new("TextLabel")
			Label.Size = UDim2.new(0.65, 0, 1, 0)
			Label.BackgroundTransparency = 1
			Label.Text = name
			Label.TextXAlignment = Enum.TextXAlignment.Left
			Label.TextColor3 = Color3.new(1,1,1)
			Label.Font = Enum.Font.Gotham
			Label.TextScaled = true
			Label.Parent = Frame

			local DropdownBtn = Instance.new("TextButton")
			DropdownBtn.Size = UDim2.new(0.32, 0, 0.8, 0)
			DropdownBtn.Position = UDim2.new(0.66, 0, 0.1, 0)
			DropdownBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
			DropdownBtn.Text = default or options[1]
			DropdownBtn.TextColor3 = Color3.new(1,1,1)
			DropdownBtn.Font = Enum.Font.Gotham
			DropdownBtn.TextScaled = true
			DropdownBtn.Parent = Frame

			local DCorner = Instance.new("UICorner")
			DCorner.CornerRadius = UDim.new(0, 8)
			DCorner.Parent = DropdownBtn

			local ListFrame = Instance.new("Frame")
			ListFrame.Size = UDim2.new(0.32, 0, 0, 0)
			ListFrame.Position = UDim2.new(0.66, 0, 1, 8)
			ListFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
			ListFrame.Visible = false
			ListFrame.Parent = Frame

			local LCorner = Instance.new("UICorner")
			LCorner.CornerRadius = UDim.new(0, 10)
			LCorner.Parent = ListFrame

			local Scrolling = Instance.new("ScrollingFrame")
			Scrolling.Size = UDim2.new(1,0,1,0)
			Scrolling.BackgroundTransparency = 1
			Scrolling.ScrollBarThickness = 4
			Scrolling.Parent = ListFrame

			local LL = Instance.new("UIListLayout")
			LL.Padding = UDim.new(0, 2)
			LL.SortOrder = Enum.SortOrder.LayoutOrder
			LL.Parent = Scrolling

			local open = false

			DropdownBtn.MouseButton1Click:Connect(function()
				open = not open
				if open then
					local h = math.min(#options * 38, 190)
					ListFrame.Visible = true
					TweenService:Create(ListFrame, TweenInfo.new(0.35, Enum.EasingStyle.Quint), {Size = UDim2.new(0.32, 0, 0, h)}):Play()
				else
					TweenService:Create(ListFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {Size = UDim2.new(0.32, 0, 0, 0)}):Play()
					task.wait(0.32)
					ListFrame.Visible = false
				end
			end)

			for _, opt in ipairs(options) do
				local Opt = Instance.new("TextButton")
				Opt.Size = UDim2.new(1,0,0,36)
				Opt.BackgroundColor3 = Color3.fromRGB(40,40,40)
				Opt.Text = opt
				Opt.TextColor3 = Color3.new(1,1,1)
				Opt.Font = Enum.Font.Gotham
				Opt.TextScaled = true
				Opt.Parent = Scrolling

				local OC = Instance.new("UICorner")
				OC.CornerRadius = UDim.new(0, 6)
				OC.Parent = Opt

				Opt.MouseButton1Click:Connect(function()
					DropdownBtn.Text = opt
					open = false
					TweenService:Create(ListFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quint), {Size = UDim2.new(0.32, 0, 0, 0)}):Play()
					task.wait(0.25)
					ListFrame.Visible = false
					if callback then callback(opt) end
				end)
			end
			Scrolling.CanvasSize = UDim2.new(0,0,0,#options*38)
		end

		-- Premier tab sélectionné
		if not self.CurrentTab then
			TabButton.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
			Page.Visible = true
			self.TitleLabel.Text = name
			self.CurrentTab = {Page = Page, Button = TabButton}
		end

		return Tab
	end

	return self
end

return AquaPulse
